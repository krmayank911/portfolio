<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{% if title %}{{ title }} | {% endif %}Mayank – Android Lead</title>
  <meta name="description" content="{% if description %}{{ description }}{% else %}Lead Android Engineer with 8+ years of experience building scalable mobile applications.{% endif %}">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=JetBrains+Mono:ital,wght@0,400;0,500;1,400&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="{{ '/css/style.css' | url }}">
  {% if syntaxHighlighting %}<link rel="stylesheet" href="{{ '/css/prism-theme.css' | url }}">{% endif %}
</head>
<body>
  {% include "nav.njk" %}
  <main id="main">
    {{ content | safe }}
  </main>
  {% include "footer.njk" %}
  <script src="{{ '/js/main.js' | url }}"></script>
</body>
</html>
