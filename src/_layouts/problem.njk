---
layout: base
syntaxHighlighting: true
---
<article class="problem-detail">
  <div class="container container-narrow">

    <div class="detail-back">
      <a href="{{ '/problems/' | url }}" class="back-link">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 12H5M12 5l-7 7 7 7"/></svg>
        Problems I Solved
      </a>
    </div>

    <header class="detail-header">
      <h1 class="detail-title">{{ title }}</h1>
      {% if date %}<p class="detail-date">{{ date | dateFormat }}</p>{% endif %}
      {% if tags %}
      <div class="tag-list">
        {% for tag in tags %}<span class="tag">{{ tag }}</span>{% endfor %}
      </div>
      {% endif %}
    </header>

    {% if metrics %}
    <div class="metrics-box">
      <p class="metrics-label">Key Outcomes</p>
      <ul class="metrics-list">
        {% for m in metrics %}<li>{{ m }}</li>{% endfor %}
      </ul>
    </div>
    {% endif %}

    {% if images and images.length > 0 %}
    <div class="problem-gallery">
      <p class="detail-tech-label">Screenshots</p>
      <div class="gallery-grid">
        {% for img in images %}
          {% if img.src %}
            <figure class="gallery-item" data-caption="{{ img.caption }}">
              <img src="{{ img.src | url }}" alt="{{ img.caption or title }}" loading="lazy" class="gallery-img">
              {% if img.caption %}<figcaption class="gallery-caption">{{ img.caption }}</figcaption>{% endif %}
            </figure>
          {% else %}
            <figure class="gallery-item">
              <img src="{{ img | url }}" alt="{{ title }}" loading="lazy" class="gallery-img">
            </figure>
          {% endif %}
        {% endfor %}
      </div>
    </div>
    {% endif %}

    {% if video %}
    <div class="detail-video">
      <p class="detail-tech-label">Video</p>
      <div class="video-wrapper">
        <iframe
          src="{{ video | replace('drive.google.com/file/d/', 'drive.google.com/file/d/') | replace('/view', '/preview') | replace('/view?usp=sharing', '/preview') | replace('/view?usp=drive_link', '/preview') }}"
          allow="autoplay"
          allowfullscreen
          loading="lazy"
          class="video-embed">
        </iframe>
      </div>
    </div>
    {% endif %}

    <div class="problem-content article-content">
      {{ content | safe }}
    </div>

    {% if tech %}
    <div class="detail-tech">
      <p class="detail-tech-label">Tech Used</p>
      <div class="tag-list">
        {% for t in tech %}<span class="tag tag-tech">{{ t }}</span>{% endfor %}
      </div>
    </div>
    {% endif %}

  </div>
</article>
