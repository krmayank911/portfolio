---
layout: base
syntaxHighlighting: true
---
<article class="problem-detail">
  <div class="container container-narrow">

    <div class="detail-back">
      <a href="{{ '/problems/' | url }}" class="back-link">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 12H5M12 5l-7 7 7 7"/></svg>
        Problems I Solved
      </a>
    </div>

    <header class="detail-header">
      <h1 class="detail-title">{{ title }}</h1>
      {% if date %}<p class="detail-date">{{ date | dateFormat }}</p>{% endif %}
      {% if tags %}
      <div class="tag-list">
        {% for tag in tags %}<span class="tag">{{ tag }}</span>{% endfor %}
      </div>
      {% endif %}
    </header>

    {% if showcase and showcase.length > 0 %}
    <div class="project-carousel" data-carousel>
      <div class="carousel-track">

        {% for item in showcase %}
          {% if item.type == "video" %}
            {% set videoEmbed = item.src | replace('/view?usp=drive_link', '/preview') | replace('/view?usp=sharing', '/preview') | replace('/view', '/preview') %}
            {% set vAspect = item.aspect or "16/9" %}
            <div class="carousel-slide carousel-slide-video" data-video="{{ videoEmbed }}" style="aspect-ratio: {{ vAspect }};">
              <div class="carousel-video-thumb">
                {% if item.thumbnail %}
                <img src="{{ item.thumbnail | url }}" alt="{{ item.caption or title }}" class="carousel-video-thumbnail-img">
                {% endif %}
                <div class="carousel-play-icon">
                  <svg width="28" height="28" viewBox="0 0 24 24" fill="currentColor"><polygon points="5 3 19 12 5 21 5 3"/></svg>
                </div>
              </div>
            </div>
          {% elif item.type == "image" %}
            <div class="carousel-slide carousel-slide-img">
              <img src="{{ item.src | url }}" alt="{{ item.caption or title }}" loading="lazy" class="carousel-img" data-caption="{{ item.caption }}">
            </div>
          {% endif %}
        {% endfor %}

      </div>
      <button class="carousel-btn carousel-prev" aria-label="Previous" hidden>
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M15 18l-6-6 6-6"/></svg>
      </button>
      <button class="carousel-btn carousel-next" aria-label="Next">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18l6-6-6-6"/></svg>
      </button>
    </div>
    {% endif %}

    {% if metrics %}
    <div class="metrics-box">
      <p class="metrics-label">Key Outcomes</p>
      <ul class="metrics-list">
        {% for m in metrics %}<li>{{ m }}</li>{% endfor %}
      </ul>
    </div>
    {% endif %}

    {% if images and images.length > 0 %}
    <div class="problem-gallery">
      <p class="detail-tech-label">Screenshots</p>
      <div class="gallery-grid">
        {% for img in images %}
          {% if img.src %}
            <figure class="gallery-item" data-caption="{{ img.caption }}">
              <img src="{{ img.src | url }}" alt="{{ img.caption or title }}" loading="lazy" class="gallery-img">
              {% if img.caption %}<figcaption class="gallery-caption">{{ img.caption }}</figcaption>{% endif %}
            </figure>
          {% else %}
            <figure class="gallery-item">
              <img src="{{ img | url }}" alt="{{ title }}" loading="lazy" class="gallery-img">
            </figure>
          {% endif %}
        {% endfor %}
      </div>
    </div>
    {% endif %}

    {% if video %}
    <div class="detail-video">
      <p class="detail-tech-label">Video</p>
      <div class="video-wrapper">
        <iframe
          src="{{ video | replace('drive.google.com/file/d/', 'drive.google.com/file/d/') | replace('/view', '/preview') | replace('/view?usp=sharing', '/preview') | replace('/view?usp=drive_link', '/preview') }}"
          allow="autoplay"
          allowfullscreen
          loading="lazy"
          class="video-embed">
        </iframe>
      </div>
    </div>
    {% endif %}

    <div class="problem-content article-content">
      {{ content | safe }}
    </div>

    {% if tech %}
    <div class="detail-tech">
      <p class="detail-tech-label">Tech Used</p>
      <div class="tag-list">
        {% for t in tech %}<span class="tag tag-tech">{{ t }}</span>{% endfor %}
      </div>
    </div>
    {% endif %}

  </div>
</article>
